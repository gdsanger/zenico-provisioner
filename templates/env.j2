DB_PASSWORD={{ db_password }}
DATABASE_URL=postgres://{{ db_user }}:{{ db_password }}@db:5432/{{ db_name }}

CELERY_BROKER_URL=redis://redis:6379/0

KI_ADDON_ENABLED={{ ki_addon_enabled | lower }}
