SECRET_KEY={{ secret_key }}
FIELD_ENCRYPTION_KEY={{ field_encryption_key }}
ALLOWED_HOSTS={{ allowed_hosts }}
SITE_URL={{ site_url }}
DJANGO_SETTINGS_MODULE=config.settings.production

DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASSWORD={{ db_password }}
DATABASE_URL=postgres://{{ db_user }}:{{ db_password }}@db:5432/{{ db_name }}

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

KI_ADDON_ENABLED={{ ki_addon_enabled | lower }}

# Phone-Home / Lizenz-Sync mit Zenico.admin (API-CONTRACT.md, Abschnitt 1)
ZENICO_ADMIN_URL={{ zenico_admin_url }}
ZENICO_API_KEY={{ zenico_api_key }}
ZENICO_INSTANCE_ID={{ zenico_instance_id }}
ZENICO_CUSTOMER_ID={{ zenico_customer_id }}
