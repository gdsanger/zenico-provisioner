# Basis-URL von Zenico.admin (ohne abschließenden Slash)
ADMIN_API_URL=https://admin.zenico.app

# Bearer-Token für die Agent<->Admin Kommunikation
ADMIN_API_TOKEN=your-secret-token-here

# Image-Pfad des Zenico-app-Images (ohne Tag)
DOCKER_IMAGE=registry.angermeier.net/zenico-app

# Basisverzeichnis auf dem Host, in dem pro Kunde ein Unterverzeichnis angelegt wird
INSTANCES_DIR=/srv/zenico/instances

# Name des externen Docker-Netzwerks, in dem Nginx Proxy Manager läuft
PROXY_NETWORK=npm_proxy

# Sekunden zwischen zwei Polls (Default: 30)
POLL_INTERVAL=30

# Sekunden bis ein Health-Check als gescheitert gilt (Default: 120)
HEALTH_TIMEOUT=120

# --- Nginx Proxy Manager (optional) ---
# Sind alle drei gesetzt, legt der Agent den Proxy-Host inkl. Let's-Encrypt-
# Zertifikat automatisch an. Fehlen sie, bleibt das ein manueller Schritt in
# NPM (der Agent gibt dann nur einen Log-Hinweis aus, kein Fehler).
NPM_API_URL=https://npm.zenico.app
NPM_API_EMAIL=admin@example.com
NPM_API_PASSWORD=your-npm-password-here
